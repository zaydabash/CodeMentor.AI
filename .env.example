# Backend
APP_ENV=local
DATABASE_URL=sqlite:///./codementor.db
WORKSPACE_DIR=./workspace
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MAX_TOKENS=6000
TEMPERATURE=0.2
